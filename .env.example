# PostgreSQL
POSTGRES_USER=fh6user
POSTGRES_PASSWORD=fh6pass
POSTGRES_DB=fh6dashboard

# Backend
DATABASE_URL=postgresql://fh6user:fh6pass@localhost:5432/fh6dashboard
JWT_SECRET=change_me_to_a_secure_random_string
JWT_REFRESH_SECRET=change_me_to_another_secure_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
# URL of the deployed frontend — used for CORS (set to your Vercel domain in production)
FRONTEND_URL=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
