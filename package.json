{
  "name": "fh6-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend prisma:generate && pnpm --filter backend dev",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend prisma:generate && pnpm --filter backend build",
    "test": "pnpm --filter backend test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=8.0.0"
  },
  "prisma": {
    "schema": "apps/backend/prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "vue-demi",
      "@nestjs/core",
      "@scarf/scarf"
    ]
  }
}
